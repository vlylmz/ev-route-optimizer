  "metadata": {
    "version": "1.0",
    "source": "ev-database.org, evspecs.org, manufacturer specs (WLTP)",
    "note": "HESAPLAMA OTORİTESİ: ideal_consumption_wh_km + usable_battery_kwh. wltp_range_km yalnizca referans/bilgilendirme amaclidir; farkli kaynak metodolojilerinden dolayi hesaplanan aralik ile örtüsmeyebilir. --- default_hvac_load_kw: 20C standart kosullarda tahmini HVAC yükü (kW); gercek hesapta sicakliga ve kullanici tercihine göre override edilebilir. temp_penalty_factor: 20C altinda her derece icin verimlilik kaybi katsayisi (~0.5-0.9%/C). soc_min_pct: su an tek alan olarak hem teknik alt siniri hem rota planlama rezervini temsil eder. Kod tarafinda bu deger ROTA PLANLAMA REZERVI olarak yorumlanmali. Ileride technical_soc_min_pct / routing_reserve_soc_pct olarak ayrilabilir. soc_max_pct: NMC icin önerilen günlük kullanim üst siniri (%90, uzun ömür); LFP icin teknik üst sinir (%100, LFP kimyasinda sorunsuz). charge_curve_hint: sarj egrisinin genel sekli — flat_lfp veya tapered_nmc.",
    "last_updated": "2026-03-23",
    "schema_version": "1.1",
    "design_decisions": {
      "range_authority": "ideal_consumption_wh_km and usable_battery_kwh are the source of truth for all calculations",
      "wltp_range_km": "informational only — do not use for route math",
      "soc_min_pct": "treated as routing_reserve_soc_pct in optimizer; technical floor may differ",
      "future_split": "consider splitting soc_min_pct into technical_soc_min_pct and routing_reserve_soc_pct"
    }
  },
